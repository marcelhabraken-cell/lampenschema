<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#263a3a" />
    <link rel="manifest" href="manifest.webmanifest" />
    <link rel="apple-touch-icon" href="icons/icon-192.png" />
    <title>Lampenschema</title>
    <style>
:root{color-scheme:light;--ink:#182222;--muted:#62706d;--line:#d9ded8;--field:#f4f6f1;--brand:#263a3a;--accent:#c46f3b;--ok:#2f7d5b;--shadow:0 18px 45px rgba(24,34,34,.14);font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}*{box-sizing:border-box}body{margin:0;min-height:100vh;background:linear-gradient(180deg,#eef1eb 0%,#dfe6df 48%,#f7f6f1 100%);color:var(--ink)}button,input{font:inherit}.app-shell{width:min(100%,460px);min-height:100vh;margin:0 auto;padding:max(10px,env(safe-area-inset-top)) 14px max(12px,env(safe-area-inset-bottom));display:grid;gap:10px;align-content:start}.topbar{display:flex;align-items:center;justify-content:space-between;padding:4px 2px 0}.eyebrow,.label,.hint,.status,.subreadout,.import-panel p{margin:0;color:var(--muted)}.eyebrow{font-size:.78rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}h1,h2{margin:0;letter-spacing:0}h1{font-size:clamp(1.8rem,10vw,2.6rem);line-height:.98}h2{font-size:1.15rem}.icon-button,.stepper,.file-button{border:0;cursor:pointer;touch-action:manipulation}.icon-button{width:44px;height:44px;border-radius:50%;background:var(--brand);color:#fff;font-size:1.7rem;line-height:1;box-shadow:var(--shadow)}.readout,.input-panel,.details,.import-panel{background:rgba(255,255,255,.88);border:1px solid rgba(255,255,255,.75);box-shadow:var(--shadow)}.readout{min-height:150px;border-radius:8px;padding:16px 18px;display:grid;align-content:center;gap:5px}.label{font-weight:800;text-transform:uppercase;letter-spacing:.08em;font-size:.8rem}.percentage{display:flex;align-items:baseline;gap:4px;color:var(--brand);font-weight:900;line-height:.9}.percentage span:first-child{font-size:clamp(4.2rem,24vw,6.8rem)}.percentage span:last-child{font-size:1.8rem}.subreadout{min-height:1.4em;font-weight:700}.input-panel,.import-panel{border-radius:8px;padding:14px}.input-panel label{display:block;margin-bottom:7px;font-size:.95rem;font-weight:850}.number-row{display:grid;grid-template-columns:48px 1fr 48px;gap:8px;align-items:stretch}.stepper{min-height:50px;border-radius:8px;background:var(--brand);color:#fff;font-size:1.55rem;font-weight:800}input[type=number]{width:100%;min-height:50px;border:1px solid var(--line);border-radius:8px;background:var(--field);color:var(--ink);font-size:1.65rem;font-weight:850;text-align:center}.hint{margin-top:7px;font-size:.8rem;line-height:1.25}.details{border-radius:8px;overflow:hidden}.details div{display:flex;justify-content:space-between;gap:12px;padding:11px 14px;border-bottom:1px solid var(--line)}.details div:last-child{border-bottom:0}.details span{color:var(--muted);font-weight:750}.details strong{text-align:right}.import-panel{display:grid;gap:14px}.import-panel p{margin-top:4px;line-height:1.38}.file-button{display:grid;place-items:center;min-height:52px;border-radius:8px;background:var(--accent);color:#fff;font-weight:850}#fileInput{position:absolute;inline-size:1px;block-size:1px;opacity:0;pointer-events:none}.status{min-height:1.3em;font-size:.9rem}.status.good{color:var(--ok);font-weight:800}@media (min-height:760px){.app-shell{gap:12px}}
</style>
  </head>
  <body>
    <main class="app-shell">
      <section class="topbar" aria-label="App">
        <div>
          <p class="eyebrow">Edgeteq S-380</p>
          <h1>Lampenschema</h1>
        </div>
        <button class="icon-button" id="installButton" type="button" hidden title="Installeer app" aria-label="Installeer app"><span aria-hidden="true">+</span></button>
      </section>
      <section class="readout" aria-live="polite">
        <p class="label">Lamp instellen op</p>
        <div class="percentage"><span id="lampPercentage">--</span><span>%</span></div>
        <p class="subreadout" id="matchText">Importeer eerst het lampenschema.</p>
      </section>
      <section class="input-panel" aria-label="Temperatuur invoer">
        <label for="panelTemp">Paneeltemperatuur</label>
        <div class="number-row">
          <button class="stepper" type="button" data-step="-1" aria-label="Een graad lager">-</button>
          <input id="panelTemp" inputmode="decimal" type="number" min="10" step="0.1" value="10" />
          <button class="stepper" type="button" data-step="1" aria-label="Een graad hoger">+</button>
        </div>
        <p class="hint">Vanaf 10 graden. Bij tussenliggende waarden gebruikt de app de dichtstbijzijnde rij.</p>
      </section>
      <section class="details" aria-label="Details">
        <div><span>Paneel</span><strong id="panelMatch">-- °C</strong></div>
        <div><span>Lijmopbrengst</span><strong id="glueTemp">-- °C</strong></div>
      </section>
    </main>
    <script>
window.LAMPENSCHEMA_DATA = [
  {
    "panel": 10,
    "glue": 120,
    "lamp": 1
  },
  {
    "panel": 11,
    "glue": 120,
    "lamp": 0.95
  },
  {
    "panel": 12,
    "glue": 120,
    "lamp": 0.9
  },
  {
    "panel": 13,
    "glue": 120,
    "lamp": 0.8
  },
  {
    "panel": 14,
    "glue": 120,
    "lamp": 0.7
  },
  {
    "panel": 15,
    "glue": 120,
    "lamp": 0.6
  },
  {
    "panel": 16,
    "glue": 120,
    "lamp": 0.55
  },
  {
    "panel": 17,
    "glue": 120,
    "lamp": 0.5
  },
  {
    "panel": 18,
    "glue": 120,
    "lamp": 0.45
  },
  {
    "panel": 19,
    "glue": 120,
    "lamp": 0.4
  },
  {
    "panel": 20,
    "glue": 120,
    "lamp": 0.4
  },
  {
    "panel": 21,
    "glue": 120,
    "lamp": 0.35
  },
  {
    "panel": 22,
    "glue": 120,
    "lamp": 0.3
  },
  {
    "panel": 23,
    "glue": 120,
    "lamp": 0.25
  },
  {
    "panel": 24,
    "glue": 120,
    "lamp": 0.2
  },
  {
    "panel": 25,
    "glue": 120,
    "lamp": 0.2
  },
  {
    "panel": 26,
    "glue": 120,
    "lamp": 0.15
  },
  {
    "panel": 27,
    "glue": 120,
    "lamp": 0.1
  },
  {
    "panel": 28,
    "glue": 120,
    "lamp": 0.05
  },
  {
    "panel": 29,
    "glue": 120,
    "lamp": 0
  },
  {
    "panel": 30,
    "glue": 120,
    "lamp": 0
  }
];

(() => {
  const els = {
    lampPercentage: document.getElementById("lampPercentage"),
    matchText: document.getElementById("matchText"),
    panelTemp: document.getElementById("panelTemp"),
    panelMatch: document.getElementById("panelMatch"),
    glueTemp: document.getElementById("glueTemp"),

    installButton: document.getElementById("installButton")
  };

  const STORAGE_KEY = "lampenschema.rows.v1";
  let rows = normalizeRows(loadRows());
  let deferredInstall = null;

  function loadRows() {
    try {
      const stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || "null");
      if (Array.isArray(stored) && stored.length) return stored;
    } catch (error) {
      console.warn(error);
    }
    return Array.isArray(window.LAMPENSCHEMA_DATA) ? window.LAMPENSCHEMA_DATA : [];
  }

  function normalizeRows(input) {
    const mapped = input.map((row) => ({
      panel: toNumber(row.panel ?? row[0]),
      glue: toNumber(row.glue ?? row[1]),
      lamp: toNumber(row.lamp ?? row[2])
    }));
    const validLampValues = mapped.map((row) => row.lamp).filter(Number.isFinite);
    const maxLamp = validLampValues.length ? Math.max(...validLampValues.map(Math.abs)) : 0;
    const percentScale = maxLamp > 0 && maxLamp <= 1 ? 100 : 1;
    return mapped
      .map((row) => ({ ...row, lamp: row.lamp * percentScale }))
      .filter((row) => Number.isFinite(row.panel) && Number.isFinite(row.lamp) && row.panel >= 10)
      .sort((a, b) => a.panel - b.panel);
  }

  function toNumber(value) {
    if (typeof value === "number") return value;
    if (value == null) return NaN;
    const cleaned = String(value).trim().replace(/%$/, "").replace(",", ".");
    return cleaned === "" ? NaN : Number(cleaned);
  }

  function formatNumber(value, decimals = 1) {
    if (!Number.isFinite(value)) return "--";
    const rounded = Number(value.toFixed(decimals));
    return String(rounded).replace(".", ",");
  }

  function nearestRow(temp) {
    if (!rows.length || !Number.isFinite(temp)) return null;
    let best = rows[0];
    let bestDistance = Math.abs(temp - best.panel);
    for (const row of rows) {
      const distance = Math.abs(temp - row.panel);
      if (distance < bestDistance) {
        best = row;
        bestDistance = distance;
      }
    }
    return best;
  }

  function update() {
    const value = Math.max(10, toNumber(els.panelTemp.value));
    const match = nearestRow(value);
    if (!match) {
      els.lampPercentage.textContent = "--";
      els.matchText.textContent = "Importeer eerst het lampenschema.";
      els.panelMatch.textContent = "-- °C";
      els.glueTemp.textContent = "-- °C";
      return;
    }
    els.lampPercentage.textContent = formatNumber(match.lamp, 0);
    els.panelMatch.textContent = formatNumber(match.panel) + " °C";
    els.glueTemp.textContent = Number.isFinite(match.glue) ? formatNumber(match.glue) + " °C" : "-- °C";
    const exact = Math.abs(value - match.panel) < 0.0001;
    els.matchText.textContent = exact ? "Exacte rij voor " + formatNumber(match.panel) + " °C." : "Dichtstbijzijnde rij: " + formatNumber(match.panel) + " °C.";
  }

  function parseCsv(text) {
    const table = [];
    let row = [];
    let cell = "";
    let quoted = false;
    for (let i = 0; i < text.length; i += 1) {
      const char = text[i];
      const next = text[i + 1];
      if (char === '"' && quoted && next === '"') {
        cell += '"';
        i += 1;
      } else if (char === '"') {
        quoted = !quoted;
      } else if ((char === "," || char === ";" || char === "\t") && !quoted) {
        row.push(cell);
        cell = "";
      } else if ((char === "\n" || char === "\r") && !quoted) {
        if (char === "\r" && next === "\n") i += 1;
        row.push(cell);
        table.push(row);
        row = [];
        cell = "";
      } else {
        cell += char;
      }
    }
    row.push(cell);
    table.push(row);
    return table.map(rowToSchemaRow);
  }

  function rowToSchemaRow(row) {
    const offset = row.length >= 4 ? 1 : 0;
    return { panel: row[offset], glue: row[offset + 1], lamp: row[offset + 2] };
  }

  async function parseXlsx(buffer) {
    const entries = await unzip(buffer);
    const workbookXml = textEntry(entries, "xl/workbook.xml");
    const relsXml = textEntry(entries, "xl/_rels/workbook.xml.rels");
    const sheetPath = firstSheetPath(workbookXml, relsXml);
    const sharedStrings = parseSharedStrings(entries.get("xl/sharedStrings.xml") || "");
    const sheetXml = textEntry(entries, sheetPath);
    return parseSheet(sheetXml, sharedStrings).map(rowToSchemaRow);
  }

  function textEntry(entries, name) {
    const value = entries.get(name);
    if (value == null) throw new Error("Ontbrekend onderdeel in .xlsx: " + name);
    return value;
  }

  function firstSheetPath(workbookXml, relsXml) {
    const parser = new DOMParser();
    const workbook = parser.parseFromString(workbookXml, "application/xml");
    const rels = parser.parseFromString(relsXml, "application/xml");
    const firstSheet = workbook.querySelector("sheet");
    if (!firstSheet) throw new Error("Geen werkblad gevonden.");
    const relId = firstSheet.getAttribute("r:id") || firstSheet.getAttribute("id");
    const rel = Array.from(rels.querySelectorAll("Relationship")).find((item) => item.getAttribute("Id") === relId);
    if (!rel) throw new Error("Werkbladkoppeling niet gevonden.");
    const target = rel.getAttribute("Target").replace(/^\//, "");
    return target.startsWith("xl/") ? target : "xl/" + target;
  }

  function parseSharedStrings(xml) {
    if (!xml) return [];
    const doc = new DOMParser().parseFromString(xml, "application/xml");
    return Array.from(doc.querySelectorAll("si")).map((si) => Array.from(si.querySelectorAll("t")).map((t) => t.textContent || "").join(""));
  }

  function parseSheet(xml, sharedStrings) {
    const doc = new DOMParser().parseFromString(xml, "application/xml");
    const table = [];
    for (const cell of doc.querySelectorAll("sheetData c")) {
      const ref = cell.getAttribute("r") || "";
      const match = ref.match(/^([A-Z]+)(\d+)$/);
      if (!match) continue;
      const col = columnIndex(match[1]);
      const row = Number(match[2]) - 1;
      if (!table[row]) table[row] = [];
      table[row][col] = cellValue(cell, sharedStrings);
    }
    return table.filter(Boolean);
  }

  function cellValue(cell, sharedStrings) {
    const type = cell.getAttribute("t");
    if (type === "inlineStr") return cell.querySelector("is t")?.textContent || "";
    const raw = cell.querySelector("v")?.textContent || "";
    if (type === "s") return sharedStrings[Number(raw)] || "";
    if (type === "b") return raw === "1";
    return raw;
  }

  function columnIndex(letters) {
    let index = 0;
    for (const letter of letters) index = index * 26 + letter.charCodeAt(0) - 64;
    return index - 1;
  }

  async function unzip(buffer) {
    const bytes = new Uint8Array(buffer);
    const entries = new Map();
    const eocd = findEndOfCentralDirectory(bytes);
    const view = new DataView(buffer);
    const centralSize = view.getUint32(eocd + 12, true);
    const centralOffset = view.getUint32(eocd + 16, true);
    let offset = centralOffset;
    const end = centralOffset + centralSize;
    while (offset < end) {
      if (view.getUint32(offset, true) !== 0x02014b50) break;
      const method = view.getUint16(offset + 10, true);
      const compressedSize = view.getUint32(offset + 20, true);
      const nameLength = view.getUint16(offset + 28, true);
      const extraLength = view.getUint16(offset + 30, true);
      const commentLength = view.getUint16(offset + 32, true);
      const localOffset = view.getUint32(offset + 42, true);
      const name = decodeText(bytes.slice(offset + 46, offset + 46 + nameLength));
      const data = await readLocalEntry(bytes, view, localOffset, compressedSize, method);
      entries.set(name, data);
      offset += 46 + nameLength + extraLength + commentLength;
    }
    return entries;
  }

  function findEndOfCentralDirectory(bytes) {
    for (let i = bytes.length - 22; i >= Math.max(0, bytes.length - 66000); i -= 1) {
      if (bytes[i] === 0x50 && bytes[i + 1] === 0x4b && bytes[i + 2] === 0x05 && bytes[i + 3] === 0x06) return i;
    }
    throw new Error("Dit Excel-bestand kon niet als .xlsx worden gelezen.");
  }

  async function readLocalEntry(bytes, view, offset, compressedSize, method) {
    if (view.getUint32(offset, true) !== 0x04034b50) throw new Error("Ongeldige .xlsx structuur.");
    const nameLength = view.getUint16(offset + 26, true);
    const extraLength = view.getUint16(offset + 28, true);
    const start = offset + 30 + nameLength + extraLength;
    const compressed = bytes.slice(start, start + compressedSize);
    if (method === 0) return decodeText(compressed);
    if (method !== 8) throw new Error("Deze compressie in .xlsx wordt niet ondersteund.");
    if (!("DecompressionStream" in window)) throw new Error("Deze browser kan .xlsx niet uitpakken. Gebruik CSV als alternatief.");
    const stream = new Blob([compressed]).stream().pipeThrough(new DecompressionStream("deflate-raw"));
    const decompressed = await new Response(stream).arrayBuffer();
    return decodeText(new Uint8Array(decompressed));
  }

  function decodeText(bytes) {
    return new TextDecoder("utf-8").decode(bytes);
  }

  els.panelTemp.addEventListener("input", update);
  document.querySelectorAll("[data-step]").forEach((button) => {
    button.addEventListener("click", () => {
      const current = Math.max(10, toNumber(els.panelTemp.value) || 10);
      els.panelTemp.value = formatNumber(current + Number(button.dataset.step), 1).replace(",", ".");
      update();
    });
  });

  window.addEventListener("beforeinstallprompt", (event) => {
    event.preventDefault();
    deferredInstall = event;
    els.installButton.hidden = false;
  });
  els.installButton.addEventListener("click", async () => {
    if (!deferredInstall) return;
    deferredInstall.prompt();
    await deferredInstall.userChoice;
    deferredInstall = null;
    els.installButton.hidden = true;
  });
  update();
})();

    </script>
      <script>if ("serviceWorker" in navigator && location.protocol !== "file:") { navigator.serviceWorker.register("service-worker.js").catch(console.warn); }</script>
  </body>
</html>
